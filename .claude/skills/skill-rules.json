{
    "version": "1.0",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "backend-dev-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Backend development patterns for Spring Boot 3.x with Lombok and TestContainers",
            "promptTriggers": {
                "keywords": [
                    "backend",
                    "backend development",
                    "spring boot",
                    "controller",
                    "service",
                    "repository",
                    "entity",
                    "JPA",
                    "Hibernate",
                    "API",
                    "endpoint",
                    "REST",
                    "validation",
                    "Bean Validation",
                    "DTO",
                    "security",
                    "Spring Security",
                    "Lombok",
                    "TestContainers",
                    "configuration",
                    "ConfigurationProperties",
                    "transaction",
                    "Transactional",
                    "docker",
                    "dockerfile",
                    "docker-compose",
                    "containerize",
                    "container",
                    "deployment",
                    "buildpacks",
                    "jib"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(endpoint|API|controller|service|repository|entity)",
                    "(fix|handle|debug).*?(error|exception|backend)",
                    "(add|implement).*?(validation|error.*?handling|security)",
                    "(organize|structure|refactor).*?(backend|service|API)",
                    "(how to|best practice).*?(spring|controller|service|JPA)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src/main/java/**/*.java",
                    "**/controller/**/*.java",
                    "**/service/**/*.java",
                    "**/repository/**/*.java",
                    "**/entity/**/*.java",
                    "**/dto/**/*.java",
                    "**/config/**/*.java",
                    "**/Dockerfile*",
                    "**/docker-compose*.yml",
                    "**/docker-compose*.yaml"
                ],
                "pathExclusions": [
                    "**/test/**/*.java",
                    "**/*Test.java",
                    "**/*Tests.java"
                ],
                "contentPatterns": [
                    "@RestController",
                    "@Controller",
                    "@Service",
                    "@Repository",
                    "@Entity",
                    "@Configuration",
                    "JpaRepository",
                    "@Transactional"
                ]
            }
        },
        "route-tester": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Testing REST endpoints in Spring Boot applications with MockMvc and TestContainers",
            "promptTriggers": {
                "keywords": [
                    "test endpoint",
                    "test API",
                    "test controller",
                    "MockMvc",
                    "WebMvcTest",
                    "SpringBootTest",
                    "TestContainers",
                    "integration test",
                    "API testing"
                ],
                "intentPatterns": [
                    "(test|debug|verify).*?(endpoint|API|controller)",
                    "(how to|how do I).*?test.*?(endpoint|API|controller)",
                    "test.*?(authenticated|auth|security)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/controller/**/*.java",
                    "**/*Test.java",
                    "**/*Tests.java",
                    "**/test/**/*.java"
                ],
                "contentPatterns": [
                    "@WebMvcTest",
                    "@SpringBootTest",
                    "MockMvc",
                    "@Testcontainers"
                ]
            }
        },
        "git-workflow": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Git workflow standards for branch management, commits, and pre-commit testing",
            "promptTriggers": {
                "keywords": [
                    "git",
                    "commit",
                    "branch",
                    "merge",
                    "pull request",
                    "PR",
                    "push",
                    "checkout",
                    "rebase",
                    "git workflow",
                    "commit message",
                    "feature branch",
                    "start task",
                    "start story",
                    "new feature"
                ],
                "intentPatterns": [
                    "(create|start|make).*?(branch|feature|task)",
                    "(commit|push|merge).*?(change|code)",
                    "(how to|best practice).*?(commit|branch|git)",
                    "(finish|complete|end).*?(task|story|feature)"
                ]
            }
        },
        "error-tracking": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Centralized logging, exception handling, and monitoring patterns for Spring Boot",
            "promptTriggers": {
                "keywords": [
                    "error handling",
                    "exception",
                    "logging",
                    "error tracking",
                    "ControllerAdvice",
                    "ExceptionHandler",
                    "monitoring",
                    "Actuator",
                    "Slf4j"
                ],
                "intentPatterns": [
                    "(add|create|implement|setup).*?(error handling|exception|logging)",
                    "(fix|handle|catch).*?(error|exception)",
                    "(how to|best practice).*?(error|logging|monitoring)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/exception/**/*.java",
                    "**/*ExceptionHandler.java",
                    "**/*Controller.java",
                    "**/*Service.java"
                ],
                "contentPatterns": [
                    "@ControllerAdvice",
                    "@ExceptionHandler",
                    "@Slf4j",
                    "log\\.(error|warn|info)"
                ]
            }
        },
        "product-owner": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Product ownership patterns for feature definition, user stories, acceptance criteria, and task breakdown",
            "promptTriggers": {
                "keywords": [
                    "product owner",
                    "user story",
                    "user stories",
                    "acceptance criteria",
                    "feature definition",
                    "epic",
                    "requirements",
                    "task breakdown",
                    "split task",
                    "break down",
                    "definition of done",
                    "scope",
                    "in scope",
                    "out of scope",
                    "given when then",
                    "as a user",
                    "so that",
                    "feature spec",
                    "feature documentation",
                    "requirements doc",
                    "story points",
                    "sprint planning",
                    "backlog"
                ],
                "intentPatterns": [
                    "(define|create|write).*?(feature|requirement|story|epic)",
                    "(break|split).*?(down|into|task|story)",
                    "(acceptance|done).*?criteria",
                    "(organize|structure).*?(feature|requirement).*?doc",
                    "(plan|scope).*?(feature|epic|work)",
                    "how (to|do I).*?(write|define).*?(story|requirement|feature)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/docs/features/**/*.md",
                    "**/documentation/features/**/*.md",
                    "**/requirements/**/*.md",
                    "**/*requirements*.md",
                    "**/*stories*.md",
                    "**/*epic*.md"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "customization": {
            "pathPatterns": "Adjust to match your project structure",
            "keywords": "Add domain-specific terms relevant to your project",
            "intentPatterns": "Use regex for flexible user intent matching"
        }
    }
}
